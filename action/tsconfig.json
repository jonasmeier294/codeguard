{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "..",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "paths": {
      "@/*": ["../src/*"]
    }
  },
  "include": ["./index.ts", "../src/lib/analyzer.ts", "../src/lib/ai-analyzer.ts", "../src/lib/github.ts"]
}
